# homelab-noc v2 設定ファイル例
# setup.sh 実行時に .env がない場合，このファイルが .env にコピーされます．

# タイムゾーン
TZ=Asia/Tokyo

# 管理画面やDNSを待ち受けるアドレス
# 0.0.0.0 は自宅LAN内からアクセス可能にする設定です．
# 127.0.0.1 にするとラズパイ自身からしか見えません．
BIND_ADDRESS=0.0.0.0

# Pi-hole 管理画面のパスワード
# 必ず変更してください．この値のままだと start.sh が停止します．
PIHOLE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Docker image tags
PIHOLE_TAG=latest
UPTIME_KUMA_TAG=2
NETALERTX_TAG=latest

# ポート設定
PORTAL_PORT=8080
PIHOLE_WEB_PORT=8081
PIHOLE_DNS_PORT=53
NETALERTX_PORT=20211
UPTIME_KUMA_PORT=3001

# NetAlertX のスキャン対象
# 自宅LANに合わせて変更してください．
# 例: 192.168.1.0/24, 192.168.0.0/24, 10.0.0.0/24
HOME_SUBNET=192.168.1.0/24

# 有線LANなら eth0，Wi-Fiなら wlan0 が多いです．
LAN_INTERFACE=eth0

# NetAlertX の実行UID/GID．通常はこのままでよいです．
NETALERTX_UID=20211
NETALERTX_GID=20211

# ─── Notify Hub ────────────────────────────────────────
NOTIFY_PORT=8090
NOTIFY_API_TOKEN=CHANGE_ME_NOTIFY_TOKEN
NOTIFY_UID=20212
NOTIFY_GID=20212
